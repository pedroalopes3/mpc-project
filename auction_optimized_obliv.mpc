# ─────────────────────────────────────────────────────────────────────────────
# auction_merged.mpc — Merged Dark Auction (Milestone 4)
#
# Merge de auction_improved_obvsort.mpc + auction_optimized_claude_2.mpc.
#
# Optimisações implementadas:
#
#   OPT-1  program.use_edabit(True)
#          edaBit preprocessing amortiza bit-decomposition para comparações,
#          reduzindo rounds online em ~3x para programas comparison-heavy.
#
#   OPT-2  MP-SPDZ Native Matrix Sort (order_matrix.sort())
#          Usa o sort nativo do MP-SPDZ (O(N log²N), internamente optimizado)
#          sobre uma matriz unificada [price, bid_qty, ask_qty].
#          Evita reimplementar a rede de Batcher manualmente e beneficia
#          de optimizações internas do compilador (batching de camadas).
#
#   OPT-3  Delta Accumulators para Demand/Supply
#          Após o sort, constrói delta_demand[p] e delta_supply[p] com
#          @for_range (runtime loop), evitando expansão estática O(N×R).
#          Os acumuladores demand_acc/supply_acc são actualizados com
#          O(1) adições por rung do price ladder.
#
#   OPT-4  @for_range em todos os loops sobre MAX_PRICE
#          Grafo compilado O(N + R) em vez de O(N × R).
#          Elimina o hang de compilação e o preprocessing excessivo.
#
#   OPT-5  Deferred Reveals
#          Apenas os resultados finais são revelados: clearing price,
#          volume, fills por partido. Nenhum valor intermédio é exposto.
#
#   OPT-6  Cópias pré-sort para mapeamento partido→slot
#          As cópias originais dos arrays permitem calcular eligibilidade
#          com o mapeamento correcto partido→slot após o sort.
#          Comparações (sint op cint) em vez de (sint op sint) — ~3x mais baratas.
#
# ─────────────────────────────────────────────────────────────────────────────

program.use_edabit(True)   # OPT-1

# ── Parameters ────────────────────────────────────────────────────────────────
N_PARTIES    = 3
N_ASSETS     = 3       # BTC, ETH, SOL
N_ORDERS     = 10      # ordens por partido por asset
MAX_PRICE    = 220     # tecto do price ladder
SENTINEL_ASK = MAX_PRICE + 1   # sentinela para asks inativas

TOTAL_ORDERS = N_PARTIES * N_ORDERS   # 30 ordens por asset


# ── Main Auction Function ─────────────────────────────────────────────────────

def run_auction(asset_id):
    """
    Dark auction para um asset.

    Passos:
      1. Input: ler ordens privadas de cada partido.
      2. Mascarar ordens inativas; guardar cópias pré-sort.
      3. [OPT-2] Construir order_matrix e ordenar com sort() nativo.
      4. Calcular prefix sums de supply (L→R) e demand (R→L) na matriz ordenada.
      5. [OPT-3+4] Construir delta arrays com @for_range.
      6. [OPT-4] Price scan com @for_range + acumuladores delta.
      7. Clearing price = midpoint do plateau, floor division com regint.
      8. [OPT-6] Eligibilidade com arrays pré-sort (sint op cint).
      9. Pro-rata allocation + residual.
     10. [OPT-5] Revelar apenas resultados finais.
    """

    # ── 1. Input ──────────────────────────────────────────────────────────────
    # Cada partido fornece N_ORDERS quadruplos (bid_p, bid_q, ask_p, ask_q).
    # price = 0 significa "sem ordem neste lado".
    # Layout: [partido0_ordem0, ..., partido0_ordem9, partido1_ordem0, ...]

    bids_p = sint.Array(TOTAL_ORDERS)
    bids_q = sint.Array(TOTAL_ORDERS)
    asks_p = sint.Array(TOTAL_ORDERS)
    asks_q = sint.Array(TOTAL_ORDERS)

    # Cópias pré-sort para preservar mapeamento partido→slot (OPT-6).
    # Após o sort, os arrays são reordenados; as cópias mantêm a estrutura:
    #   partido p → slots [p*N_ORDERS .. (p+1)*N_ORDERS - 1]
    bids_p_orig = sint.Array(TOTAL_ORDERS)
    bids_q_orig = sint.Array(TOTAL_ORDERS)
    asks_p_orig = sint.Array(TOTAL_ORDERS)
    asks_q_orig = sint.Array(TOTAL_ORDERS)

    idx = 0
    for party in range(N_PARTIES):
        for i in range(N_ORDERS):
            bp = sint.get_input_from(party)
            bq = sint.get_input_from(party)
            ap = sint.get_input_from(party)
            aq = sint.get_input_from(party)

            bids_p[idx] = bp;  bids_q[idx] = bq
            asks_p[idx] = ap;  asks_q[idx] = aq
            bids_p_orig[idx] = bp;  bids_q_orig[idx] = bq
            asks_p_orig[idx] = ap;  asks_q_orig[idx] = aq
            idx += 1

    # ── 2. Mascaramento de Ordens Inativas ────────────────────────────────────
    # bid inativo (price=0): qty → 0 (preço 0 fica no fundo do sort asc)
    # ask inativo (price=0): qty → 0, price → SENTINEL_ASK (fundo do sort asc)
    # Propagar mascaramento para as cópias originais.
    for i in range(TOTAL_ORDERS):
        bid_active = bids_p[i] > 0
        bids_q[i]  = bid_active * bids_q[i]
        bids_q_orig[i] = bids_q[i]

        ask_active = asks_p[i] > 0
        asks_q[i]  = ask_active * asks_q[i]
        asks_p[i]  = ask_active.if_else(asks_p[i], sint(SENTINEL_ASK))
        asks_q_orig[i] = asks_q[i]
        asks_p_orig[i] = asks_p[i]

    # ── 3. OPT-2: Construir e Ordenar a Order Matrix ──────────────────────────
    # Matriz unificada de 2*TOTAL_ORDERS linhas × 3 colunas: [price, bid_qty, ask_qty]
    # Bids: [bid_p, bid_q, 0]   — ask_qty = 0
    # Asks: [ask_p, 0, ask_q]   — bid_qty = 0
    #
    # .sort() ordena por price (coluna 0) em ordem ASCENDENTE.
    # Bids com price=0 e asks com price=SENTINEL_ASK ficam nos extremos.
    # Após o sort:
    #   - supply[i] = prefix sum da coluna 2 (asks com price <= price[i])
    #   - demand[i] = suffix sum da coluna 1 (bids com price >= price[i])

    order_matrix = sint.Matrix(2 * TOTAL_ORDERS, 3)

    for i in range(TOTAL_ORDERS):
        order_matrix[i][0]               = bids_p[i]
        order_matrix[i][1]               = bids_q[i]
        order_matrix[i][2]               = sint(0)
        order_matrix[TOTAL_ORDERS + i][0] = asks_p[i]
        order_matrix[TOTAL_ORDERS + i][1] = sint(0)
        order_matrix[TOTAL_ORDERS + i][2] = asks_q[i]

    order_matrix.sort()   # OPT-2: sort nativo O(N log²N)

    # ── 4. Prefix Sums: Supply (L→R) e Demand (R→L) ──────────────────────────
    # supply[i] = quantidade cumulativa de asks com price <= order_matrix[i][0]
    # demand[i] = quantidade cumulativa de bids com price >= order_matrix[i][0]
    #
    # Como a matriz está ordenada por price ascendente:
    #   - supply cresce da esquerda para a direita (asks mais baratos primeiro)
    #   - demand cresce da direita para a esquerda (bids mais caros primeiro)

    N_ROWS = 2 * TOTAL_ORDERS

    supply = sint.Array(N_ROWS)
    demand = sint.Array(N_ROWS)

    running_supply = sint(0)
    for i in range(N_ROWS):
        running_supply = running_supply + order_matrix[i][2]
        supply[i] = running_supply

    running_demand = sint(0)
    for i in range(N_ROWS - 1, -1, -1):
        running_demand = running_demand + order_matrix[i][1]
        demand[i] = running_demand

    # ── 5. OPT-3+4: Delta Arrays com @for_range ───────────────────────────────
    # Para o price scan por rung inteiro (1..MAX_PRICE), precisamos de D(p) e S(p)
    # como funções do preço inteiro p — não do índice na matriz ordenada.
    #
    # delta_demand[p] = quantidade de bids com price == p
    # delta_supply[p] = quantidade de asks com price == p  (excl. sentinel)
    #
    # Construídos com @for_range: grafo O(N) por iteração de runtime.
    # Custo total: (MAX_PRICE+1) × TOTAL_ORDERS = 221×30 = 6630 comparações
    # (sint == cint) — baratas (~1 triple cada).

    delta_demand = sint.Array(MAX_PRICE + 2)
    delta_supply = sint.Array(MAX_PRICE + 2)

    @for_range(MAX_PRICE + 2)
    def _init(k):
        delta_demand[k] = sint(0)
        delta_supply[k] = sint(0)

    @for_range(MAX_PRICE + 1)
    def _build_deltas(p):
        dd = sint(0)
        ds = sint(0)
        for i in range(TOTAL_ORDERS):
            dd = dd + (bids_p[i] == p) * bids_q[i]
            ds = ds + (asks_p[i] == p) * asks_q[i]
        delta_demand[p] = dd
        delta_supply[p] = ds

    # ── 6. OPT-4: Price Scan com @for_range + Acumuladores ───────────────────
    # demand_acc começa com a soma total das bids activas e DECREMENTA
    # conforme p sobe (bids com price < p expiram).
    # supply_acc começa em 0 e INCREMENTA conforme p sobe
    # (asks com price <= p tornam-se elegíveis).
    #
    # Em cada rung: 2 adições + ~4 comparações secretas = O(1).
    # Total do scan: 220 rungs × ~6 ops = ~1320 operações secretas.

    demand_acc  = sint.Array(1)
    supply_acc  = sint.Array(1)
    max_vol_arr = sint.Array(1)
    best_p_low  = sint.Array(1)
    best_p_high = sint.Array(1)

    demand_init = sint(0)
    for i in range(TOTAL_ORDERS):
        demand_init = demand_init + bids_q[i]

    demand_acc[0]  = demand_init
    supply_acc[0]  = sint(0)
    max_vol_arr[0] = sint(0)
    best_p_low[0]  = sint(0)
    best_p_high[0] = sint(0)

    @for_range(1, MAX_PRICE + 1)
    def _price_scan(p):
        # Expirar bids com price == p-1
        demand_acc[0] = demand_acc[0] - delta_demand[p - 1]
        # Activar asks com price == p
        supply_acc[0] = supply_acc[0] + delta_supply[p]

        d   = demand_acc[0]
        s   = supply_acc[0]
        vol = (d < s).if_else(d, s)   # min(D(p), S(p))

        # Mascarar preços inválidos (price=0 e sentinela)
        is_valid = (p > 0) * (p < SENTINEL_ASK)
        vol = vol * is_valid

        is_new_max   = vol > max_vol_arr[0]
        is_equal_max = (vol == max_vol_arr[0]) * (max_vol_arr[0] > 0)

        max_vol_arr[0] = is_new_max.if_else(vol, max_vol_arr[0])
        # Novo máximo: reinicia plateau para [p, p]
        best_p_low[0]  = is_new_max.if_else(sint(p), best_p_low[0])
        best_p_high[0] = is_new_max.if_else(sint(p), best_p_high[0])
        # Extensão do plateau: avança apenas best_p_high
        best_p_high[0] = is_equal_max.if_else(sint(p), best_p_high[0])

    # ── 7. Clearing Price ─────────────────────────────────────────────────────
    # p* = floor((best_p_low + best_p_high) / 2)
    #
    # REVEAL 1 — clearing price: resultado público obrigatório do auction.
    # Usamos regint // 2 para floor division correcta (cint // 2 seria
    # inversão em GF(p), não floor division).
    clearing_price_sum = (best_p_low[0] + best_p_high[0]).reveal()   # cint
    clearing_price_rev = regint(clearing_price_sum) // 2              # floor division

    # REVEAL 2 — volume: resultado público obrigatório.
    max_vol_int = regint(max_vol_arr[0].reveal())

    print_ln("Asset %s: clearing_price=%s  volume=%s",
             asset_id, clearing_price_rev, max_vol_int)

    # ── 8. OPT-6: Eligibilidade por Partido (arrays pré-sort) ────────────────
    # Usa arrays ORIGINAIS para preservar mapeamento partido→slot.
    # Comparações (sint op cint): cp_cint é público → ~3x mais barato
    # que (sint op sint).
    #
    # bid elegível: price >= clearing_price E qty > 0
    # ask elegível: price <= clearing_price E não é sentinela

    cp_cint = cint(clearing_price_rev)

    party_bid_qty = [sint(0)] * N_PARTIES
    party_ask_qty = [sint(0)] * N_PARTIES

    for party in range(N_PARTIES):
        for i in range(N_ORDERS):
            slot = party * N_ORDERS + i
            bid_elig = (bids_p_orig[slot] >= cp_cint) * (bids_q_orig[slot] > 0)
            party_bid_qty[party] = party_bid_qty[party] + bid_elig * bids_q_orig[slot]
            ask_elig = (asks_p_orig[slot] <= cp_cint) * (asks_p_orig[slot] < SENTINEL_ASK)
            party_ask_qty[party] = party_ask_qty[party] + ask_elig * asks_q_orig[slot]

    # ── 9. Lado Racionado ─────────────────────────────────────────────────────
    # demand total > supply total → bids racionados; caso contrário asks.
    total_bid_elig = sint(0)
    total_ask_elig = sint(0)
    for party in range(N_PARTIES):
        total_bid_elig = total_bid_elig + party_bid_qty[party]
        total_ask_elig = total_ask_elig + party_ask_qty[party]

    bids_rationed = total_bid_elig > total_ask_elig

    rationed_party_qty = [
        bids_rationed.if_else(party_bid_qty[p], party_ask_qty[p])
        for p in range(N_PARTIES)
    ]

    rationed_total_s = sint(0)
    for p in range(N_PARTIES):
        rationed_total_s = rationed_total_s + rationed_party_qty[p]

    # REVEAL 3 — denominador agregado: necessário para divisão da pro-rata.
    # Revelamos apenas o total agregado, não as qtds individuais por partido.
    rationed_total_int = regint(rationed_total_s.reveal())
    safe_denom = rationed_total_int + regint(rationed_total_int == 0)

    # ── 10. Pro-Rata Fills ────────────────────────────────────────────────────
    # fill_p = floor(rationed_qty_p × V* / total_rationed)
    #
    # REVEAL 4,5,6 — qty racionada por partido: resultado legítimo, equivalente
    # ao fill que um exchange comunica a cada participante.
    # Divisão com regint (aritmética pública, eficiente).

    party_fills = [regint(0)] * N_PARTIES
    total_alloc = regint(0)

    for p in range(N_PARTIES):
        rq_int = regint(rationed_party_qty[p].reveal()) ##########################################################################################
        party_fills[p] = (rq_int * max_vol_int) // safe_denom
        total_alloc = total_alloc + party_fills[p]

    # ── 11. Residual → primeiro partido elegível ──────────────────────────────################################################################
    # Unidades residuais (floor rounding) vão para o primeiro partido elegível.
    residual          = max_vol_int - total_alloc
    residual_assigned = regint(0)

    for p in range(N_PARTIES):
        rq_int            = regint(rationed_party_qty[p].reveal())
        has_elig          = regint(rq_int > 0)
        is_first          = (1 - residual_assigned) * has_elig
        party_fills[p]    = party_fills[p] + is_first * residual
        residual_assigned = residual_assigned + is_first

    # ── 12. Output ────────────────────────────────────────────────────────────
    # OPT-5: apenas resultados finais revelados.
    print_ln("Asset %s Results:", asset_id)
    print_ln("  Clearing Price    : %s", clearing_price_rev)
    print_ln("  Transacted Volume : %s", max_vol_int)
    for p in range(N_PARTIES):
        print_ln("  Party %s fill     : %s", p, party_fills[p])


# ── Main: correr auction para cada asset ─────────────────────────────────────
for asset in range(N_ASSETS):
    run_auction(asset)
